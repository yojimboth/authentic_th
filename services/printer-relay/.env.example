# Printer Relay Service Environment Configuration

# Port for the relay server to listen on (cloud side)
RELAY_PORT=9100

# Local printer host (usually localhost for local printers)
LOCAL_HOST=127.0.0.1

# Local printer port (standard ESC/POS port)
LOCAL_PRINTER_PORT=9100

# Log level (debug, info, warn, error)
LOG_LEVEL=info